/* comment.wxss */
/* AI生成：中央音乐学院实践平台MVP - 评论页面样式 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding: 0;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 认证提示 */
.auth-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background-color: #fff;
  margin-top: 100rpx;
  width: 100%;
  box-sizing: border-box;
}

.auth-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.auth-btn {
  width: 300rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 40rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

/* 表单区域 */
.form-area {
  background-color: #fff;
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.job-info {
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.job-label {
  font-size: 26rpx;
  color: #999;
}

.job-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 评分 */
.rating-area {
  display: flex;
  align-items: center;
}

.star {
  font-size: 50rpx;
  color: #ddd;
  margin-right: 16rpx;
}

.star.active {
  color: #ffc107;
}

.rating-text {
  font-size: 28rpx;
  color: #ffc107;
  margin-left: 20rpx;
}

/* 评论输入 */
.form-textarea {
  width: 100%;
  height: 250rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 提交按钮 */
.action-area {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 45rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

.submit-btn[disabled] {
  background-color: #ccc !important;
}
