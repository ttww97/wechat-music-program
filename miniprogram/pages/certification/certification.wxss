/* certification.wxss */
/* AI生成：中央音乐学院实践平台MVP - 认证材料上传页样式 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding: 0;
  padding-bottom: 150rpx;
}

/* 角色认证状态总览 */
.cert-overview {
  background-color: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.cert-overview .cert-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.cert-overview .cert-item:last-child {
  border-bottom: none;
}

.cert-overview .cert-role {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.cert-overview .cert-status {
  font-size: 26rpx;
  color: #666;
}

/* 角色选择器 */
.role-selector {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.selector-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.role-options {
  display: flex;
  gap: 20rpx;
}

.role-option {
  flex: 1;
  padding: 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.role-option.selected {
  border-color: #4A90D9;
  background-color: #E3F2FD;
  color: #4A90D9;
}

/* 全部认证完成提示 */
.all-done {
  text-align: center;
  padding: 80rpx 30rpx;
  background-color: #fff;
  margin: 20rpx 0;
}

.done-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.done-text {
  font-size: 32rpx;
  color: #4CAF50;
}

/* 状态提示条 */
.status-banner {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background-color: #fff7e6;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.status-banner.approved {
  background-color: #f6ffed;
}

.status-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.status-text {
  font-size: 28rpx;
  color: #666;
}

/* 认证说明卡片 */
.tips-card {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.tips-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-content text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 表单区域 */
.form-area {
  background-color: #fff;
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input[disabled] {
  background-color: #f5f5f5;
  color: #999;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 提交按钮 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 45rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

.submit-btn[disabled] {
  background-color: #ccc !important;
}
