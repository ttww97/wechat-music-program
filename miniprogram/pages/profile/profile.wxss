/* profile.wxss */
/* AI生成：中央音乐学院实践平台MVP - 个人中心页样式 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0;
}

/* 未登录卡片 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background-color: #fff;
  margin-top: 20rpx;
  min-height: 320rpx;
  width: 100%;
  box-sizing: border-box;
}

.avatar-placeholder {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.login-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.login-btn {
  width: 300rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 40rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

/* 用户信息卡片 */
.user-card {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #5BA0E9);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.info-text {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.role-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.role-tag.talent {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.role-tag.employer {
  background-color: #e3f2fd;
  color: #1565c0;
}

.role-tag.reviewer {
  background-color: #fff3e0;
  color: #e65100;
}

.role-tag.none {
  background-color: #ffebee;
  color: #c62828;
}

.cert-row {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 8rpx;
}

.cert-item {
  font-size: 24rpx;
  color: #666;
}

.cert-status {
  font-size: 26rpx;
  color: #999;
}

.cert-status.approved {
  color: #2e7d32;
}

.cert-status.pending {
  color: #f57c00;
}

/* 菜单卡片 */
.menu-card {
  background-color: #fff;
  overflow: hidden;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.unread-badge {
  min-width: 36rpx;
  height: 36rpx;
  background-color: #f56c6c;
  border-radius: 18rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.unread-badge text {
  color: #fff;
  font-size: 22rpx;
}

.menu-hint {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-area {
  margin-top: 60rpx;
}

.logout-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  background-color: #fff !important;
  color: #4A90D9 !important;
  border: 1rpx solid #4A90D9;
  border-radius: 40rpx;
  padding: 0;
  line-height: 1;
}

/* 底部 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.footer text {
  font-size: 24rpx;
  color: #ccc;
}

.version {
  margin-top: 10rpx;
}
