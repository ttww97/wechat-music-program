<!-- chatList.wxml -->
<!-- 聊天列表页 -->
<view class="container">
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && conversations.length === 0}}">
    <text class="empty-icon">💬</text>
    <text class="empty-text">暂无消息</text>
    <text class="empty-tip">去需求广场浏览，发起聊天吧</text>
  </view>

  <!-- 会话列表 -->
  <view class="conversation-list" wx:else>
    <view 
      class="conversation-item" 
      wx:for="{{conversations}}" 
      wx:key="_id"
      bindtap="goChat"
      data-conversation="{{item}}"
    >
      <!-- 头像 -->
      <view class="avatar">
        <text>{{item.otherUser.realName ? item.otherUser.realName[0] : '用'}}</text>
        <view class="unread-dot" wx:if="{{item.unreadCount > 0}}"></view>
      </view>
      
      <!-- 会话信息 -->
      <view class="conversation-info">
        <view class="top-row">
          <text class="name">{{item.otherUser.realName || '用户'}}</text>
          <text class="time">{{item.timeStr}}</text>
        </view>
        <view class="bottom-row">
          <text class="last-message">{{item.lastMessage || '暂无消息'}}</text>
          <view class="unread-badge" wx:if="{{item.unreadCount > 0}}">
            <text>{{item.unreadCount > 99 ? '99+' : item.unreadCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
