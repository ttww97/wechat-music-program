<!-- notifications.wxml -->
<view class="container">

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{isEmpty}}" class="empty-state">
    <text class="empty-icon">🔔</text>
    <text class="empty-title">暂无通知</text>
    <text class="empty-desc">认证审核结果和评论审核结果将在这里通知您</text>
  </view>

  <!-- 通知列表 -->
  <view wx:else>
    <view wx:for="{{notificationList}}" wx:key="_id" class="notification-item {{item.isRead ? '' : 'unread'}}">
      <!-- 图标 -->
      <text class="notif-icon">{{item.icon}}</text>
      <!-- 内容 -->
      <view class="notif-body">
        <text class="notif-content">{{item.content}}</text>
        <text class="notif-time">{{item.createTimeStr}}</text>
      </view>
      <!-- 未读红点 -->
      <view wx:if="{{!item.isRead}}" class="unread-dot"></view>
    </view>
  </view>

</view>
