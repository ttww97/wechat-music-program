/**index.wxss**/
/* AI生成：中央音乐学院实践平台MVP - 需求列表页样式 | 风格参考：Boss直聘 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding: 0;
}

/* 筛选栏 - 占满屏幕宽度 */
.filter-bar {
  display: flex;
  width: 100%;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-left,
.filter-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
}

.filter-left {
  border-right: 1rpx solid #eee;
}

.filter-text {
  font-size: 28rpx;
  color: #333;
}

.filter-text.active {
  color: #4A90D9;
}

.check-icon {
  font-size: 24rpx;
}

.sort-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.arrow-icon {
  font-size: 20rpx;
  margin-left: 6rpx;
  color: #999;
}

/* 技能筛选栏 */
.skill-filter-bar {
  display: flex;
  white-space: nowrap;
  background-color: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.skill-filter-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.skill-filter-item text {
  font-size: 26rpx;
  color: #666;
}

.skill-filter-item.active {
  background-color: #E3F2FD;
}

.skill-filter-item.active text {
  color: #4A90D9;
  font-weight: 500;
}

/* 需求列表 */
.job-list {
  width: 100%;
  padding: 0;
  margin: 0;
}

.job-card {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 1rpx;
  width: 100%;
  box-sizing: border-box;
}

.job-main {
  flex: 1;
  margin-right: 20rpx;
}

.job-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.job-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.3;
  flex: 1;
}

.cert-tag {
  margin-left: 12rpx;
  padding: 2rpx 8rpx;
  background-color: #E8F5E9;
  border-radius: 4rpx;
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  line-height: 1;
}

.cert-tag text {
  font-size: 20rpx;
  color: #4CAF50;
}

/* 需求描述 */
.job-desc {
  margin-bottom: 12rpx;
}

.job-desc text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 技能标签 */
.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.skill-tag {
  padding: 6rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #666;
}

/* 底部信息 */
.job-meta {
  display: flex;
  align-items: center;
}

.job-time {
  font-size: 24rpx;
  color: #999;
}

/* 右侧薪资 - Boss特色 */
.job-salary {
  text-align: right;
}

.job-salary text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6633;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.loading-icon {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-state text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx;
}

.no-more text {
  font-size: 24rpx;
  color: #ccc;
}

/* 排序选择器弹窗 */
.sort-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 1000;
}

.sort-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.sort-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-header text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.picker-options {
  padding: 20rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.picker-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.picker-option text {
  font-size: 30rpx;
  color: #333;
}

.picker-option.active text {
  color: #4A90D9;
}

.check-mark {
  color: #4A90D9;
  font-size: 32rpx;
}
