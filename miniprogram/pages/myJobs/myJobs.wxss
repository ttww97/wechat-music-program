/* myJobs.wxss */
/* 我的发布页面样式 */

page {
  background-color: #f5f5f5;
}

.container {
  padding: 0;
}

/* 需求列表 */
.job-list {
  width: 100%;
  padding: 0;
}

.job-card {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 1rpx;
  width: 100%;
  box-sizing: border-box;
}

.job-main {
  flex: 1;
}

.job-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  flex: 1;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
}

.status-tag.active {
  background-color: #e8f5e9;
  color: #4CAF50;
}

.status-tag.inactive {
  background-color: #ffebee;
  color: #f44336;
}

/* 需求描述 */
.job-desc {
  margin-bottom: 16rpx;
}

.job-desc text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 技能标签 */
.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.skill-tag {
  padding: 6rpx 16rpx;
  background-color: #f5f5f5;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
}

/* 底部信息 */
.job-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.job-time {
  font-size: 24rpx;
  color: #999;
}

.job-salary {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 500;
}

/* 操作按钮 */
.job-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-btn {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.edit {
  background-color: #e3f2fd;
  color: #1976d2;
}

.action-btn.offline {
  background-color: #ffebee;
  color: #f44336;
}

.action-btn.online {
  background-color: #e8f5e9;
  color: #4CAF50;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background-color: #fff;
  margin-top: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.publish-btn {
  width: 300rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  font-size: 28rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #ccc;
  font-size: 24rpx;
}
