/* miniprogram/pages/jobDetail/jobDetail.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.job-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.cert-badge {
  width: 40rpx;
  height: 40rpx;
  margin-left: 10rpx;
}

.info-row {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
  min-width: 120rpx;
}

.salary {
  font-size: 32rpx;
  color: #ff5722;
  font-weight: bold;
}

.skills {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}

.skill-tag {
  background-color: #e8f5e9;
  color: #2e7d32;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx; /* 圆角标签 */
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.description {
  margin-bottom: 40rpx;
}

.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-top: 10rpx;
}

.contact-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.contact-box {
  background-color: #f0f9ff;
  padding: 20rpx;
  border-radius: 8rpx;
}

.contact-text {
  font-size: 30rpx;
  color: #0288d1;
  font-weight: bold;
  display: block;
}

/* 联系方式框内的聊天按钮 */
.chat-btn-inline {
  margin-top: 16rpx;
  background-color: #4A90D9;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  display: inline-block;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 遮罩层样式 */
.mask {
  background-color: rgba(0, 0, 0, 0.05); /* 半透明遮罩 */
  padding: 30rpx;
  border-radius: 8rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.mask-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.cert-btn {
  background-color: #07c160 !important; /* 微信绿 */
}

.action-area {
  margin-top: 60rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chat-btn {
  background-color: #4A90D9;
  color: #fff;
  font-size: 30rpx;
  padding: 20rpx 60rpx;
  border-radius: 44rpx;
}

.comment-btn {
  background-color: #fff;
  color: #333;
  border: 1rpx solid #ddd;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
}

.loading-state {
  text-align: center;
  padding-top: 100rpx;
  color: #999;
}

/* ── 评论区 ────────────────────────────────────────────── */

.comment-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.comment-stats {
  display: flex;
  align-items: baseline;
}

.avg-score {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff9800;
}

.avg-unit {
  font-size: 24rpx;
  color: #ff9800;
  margin-right: 10rpx;
}

.comment-count {
  font-size: 24rpx;
  color: #999;
}

/* 单条评论 */
.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-meta {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.commenter-name {
  font-size: 26rpx;
  color: #555;
  margin-right: 16rpx;
}

.stars-row {
  display: flex;
}

.star {
  font-size: 28rpx;
  color: #ddd;   /* 默认未填充：灰色 */
}

.star-filled {
  color: #ff9800; /* 填充：橙色 */
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

/* 加载更多 */
.load-more-area {
  text-align: center;
  padding: 20rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #4A90D9;
}

.no-more-comment {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

/* 空状态 */
.no-comment {
  text-align: center;
  padding: 40rpx 0;
}

.no-comment-text {
  font-size: 28rpx;
  color: #999;
}

.comment-loading {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #bbb;
}
