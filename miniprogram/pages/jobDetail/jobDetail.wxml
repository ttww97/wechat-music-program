<!-- miniprogram/pages/jobDetail/jobDetail.wxml -->
<!-- 修改记录：2026-03-11 - 添加评论列表区域 -->
<view class="container">
  <view wx:if="{{job}}">
    <!-- ── 需求详情卡片 ────────────────────────────────── -->
    <view class="job-card">
      <!-- 标题与认证标识 -->
      <view class="header">
        <text class="title">{{job.title}}</text>
        <image wx:if="{{job.employer.isCertified}}" class="cert-badge" src="/images/icons/business-active.png" mode="aspectFit"></image>
      </view>

      <!-- 实践补贴 -->
      <view class="info-row">
        <text class="label">实践补贴</text>
        <text class="salary">💰 {{job.salary}}</text>
      </view>

      <!-- 技能标签 -->
      <view class="skills">
        <text wx:for="{{job.skills}}" wx:key="index" class="skill-tag">{{item}}</text>
      </view>

      <!-- 需求详情 -->
      <view class="description">
        <text class="label">实践需求详情</text>
        <text class="content">{{job.description}}</text>
      </view>

      <!-- 联系方式区域（安全核心，前端+云函数双重校验） -->
      <view class="contact-section">
        <text class="label">联系方式</text>

        <!-- 已认证音乐人才/发布者本人可见 -->
        <view class="contact-box" wx:if="{{showContact}}">
          <text class="contact-text">{{job.contact}}</text>
          <button class="chat-btn-inline" wx:if="{{!isOwner}}" bindtap="goChat">💬 发起聊天</button>
          <text class="tip" wx:else>您发布的需求</text>
        </view>

        <!-- 未认证用户显示遮罩 -->
        <view class="mask" wx:else>
          <text class="mask-text">🔒 完成央音认证后可见</text>
          <button class="cert-btn" bindtap="goCertify" type="primary" size="mini">立即认证</button>
        </view>
      </view>

      <!-- 评价入口（仅已认证音乐人才可见） -->
      <view class="action-area" wx:if="{{canComment}}">
        <button class="comment-btn" bindtap="goComment">⭐ 评价此需求</button>
      </view>
    </view>

    <!-- ── 用户评价区 ──────────────────────────────────── -->
    <view class="comment-section">
      <!-- 评价头部：统计信息 -->
      <view class="comment-header">
        <text class="section-title">用户评价</text>
        <view class="comment-stats" wx:if="{{totalComments > 0}}">
          <text class="avg-score">{{avgRating}}</text>
          <text class="avg-unit">分</text>
          <text class="comment-count">（共 {{totalComments}} 条）</text>
        </view>
      </view>

      <!-- 评论列表 -->
      <view wx:if="{{commentList.length > 0}}">
        <view wx:for="{{commentList}}" wx:key="_id" class="comment-item">
          <!-- 评论者信息行 -->
          <view class="comment-meta">
            <text class="commenter-name">{{item.userName || '匿名用户'}}</text>
            <!-- 星级显示（用固定数组遍历，避免 WXML 中复杂逻辑） -->
            <view class="stars-row">
              <text class="star {{item.rating >= 1 ? 'star-filled' : ''}}">★</text>
              <text class="star {{item.rating >= 2 ? 'star-filled' : ''}}">★</text>
              <text class="star {{item.rating >= 3 ? 'star-filled' : ''}}">★</text>
              <text class="star {{item.rating >= 4 ? 'star-filled' : ''}}">★</text>
              <text class="star {{item.rating >= 5 ? 'star-filled' : ''}}">★</text>
            </view>
          </view>
          <!-- 评论内容 -->
          <text class="comment-content">{{item.content}}</text>
        </view>

        <!-- 加载更多 / 已到底 -->
        <view class="load-more-area" wx:if="{{hasMoreComments}}" bindtap="loadMoreComments">
          <text wx:if="{{!loadingComments}}" class="load-more-text">查看更多评论</text>
          <text wx:else class="load-more-text">加载中...</text>
        </view>
        <view class="no-more-comment" wx:else>
          <text>—— 已显示全部评价 ——</text>
        </view>
      </view>

      <!-- 无评论空状态 -->
      <view wx:elif="{{!loadingComments}}" class="no-comment">
        <text class="no-comment-text">暂无评价，{{canComment ? '快来第一个评价吧！' : '完成认证后可发表评价'}}</text>
      </view>

      <!-- 首次加载中 -->
      <view wx:if="{{loadingComments && commentList.length === 0}}" class="comment-loading">
        <text>加载评价中...</text>
      </view>
    </view>
  </view>

  <!-- 页面加载中 -->
  <view wx:else class="loading-state">
    <text>加载中...</text>
  </view>
</view>
