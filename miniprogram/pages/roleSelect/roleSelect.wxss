/* roleSelect.wxss */
/* AI生成：中央音乐学院实践平台MVP - 角色选择页样式 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding: 0;
  padding-top: 40rpx;
  padding-bottom: 150rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding: 0 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.role-card {
  background-color: #fff;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
  width: 100%;
  box-sizing: border-box;
}

.role-card.selected {
  background-color: #f0f7ff;
}

.role-icon {
  font-size: 60rpx;
  margin-right: 30rpx;
}

.role-info {
  flex: 1;
}

.role-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.role-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.check-mark {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #4A90D9;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.tips {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #fffbe6;
  border-radius: 10rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
}

.action-area {
  margin-top: 80rpx;
}

.confirm-btn {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 45rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

.confirm-btn[disabled] {
  background-color: #ccc !important;
}

.skip-link {
  text-align: center;
  margin-top: 30rpx;
  padding: 20rpx;
}

.skip-link text {
  font-size: 28rpx;
  color: #999;
}
