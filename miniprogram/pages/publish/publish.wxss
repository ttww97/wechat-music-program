/* publish.wxss */
/* AI生成：中央音乐学院实践平台MVP - 发布需求页样式 */

page {
  background-color: #f5f5f5;
  padding: 0;
  margin: 0;
}

.container {
  padding: 0;
  padding-bottom: 150rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 认证提示区块 */
.auth-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background-color: #fff;
  margin-top: 20rpx;
  min-height: 320rpx;
  width: 100%;
  box-sizing: border-box;
}

.auth-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.auth-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.auth-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.auth-btn {
  width: 300rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 40rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

/* 表单区域 */
.form-area {
  background-color: #fff;
  padding: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 技能标签 */
.selected-skills {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.skill-tag {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #f0f7ff;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #1890ff;
}

.skill-tag.selected {
  background-color: #C41230;
  color: #fff;
}

.remove-btn {
  margin-left: 10rpx;
  font-size: 28rpx;
}

.skill-options {
  margin-bottom: 20rpx;
}

.option-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.options-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-option {
  padding: 8rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.skill-option.disabled {
  background-color: #e5e5e5;
  color: #ccc;
}

.skill-input-wrap {
  display: flex;
  gap: 16rpx;
}

.skill-input {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.add-skill-btn {
  background-color: #f5f5f5 !important;
  color: #666 !important;
  font-size: 26rpx !important;
}

/* 提交按钮 */
.action-area {
  margin-top: 60rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 45rpx;
  background-color: #4A90D9 !important;
  color: #fff;
  padding: 0;
  line-height: 1;
}

.submit-btn[disabled] {
  background-color: #ccc !important;
}
