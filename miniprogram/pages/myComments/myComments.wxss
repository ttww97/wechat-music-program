/* myComments.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

/* 状态 */
.loading-state {
  text-align: center;
  padding-top: 120rpx;
  color: #bbb;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding-top: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon  { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 32rpx; color: #555; margin-bottom: 12rpx; }
.empty-desc  { font-size: 26rpx; color: #aaa; line-height: 1.5; padding: 0 60rpx; text-align: center; }

/* 评论卡片 */
.comment-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* 星级 */
.stars-row {
  display: flex;
  align-items: center;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star-filled {
  color: #ff9800;
}

.rating-num {
  font-size: 24rpx;
  color: #ff9800;
  margin-left: 8rpx;
}

/* 状态徽章 */
.status-badge {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* 评论内容 */
.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

/* 底部信息行 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.comment-time {
  font-size: 24rpx;
  color: #bbb;
}

.view-job {
  font-size: 24rpx;
  color: #4A90D9;
}

/* 拒绝原因 */
.reject-reason {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #fff3f3;
  border-radius: 8rpx;
  border-left: 4rpx solid #f44336;
}

.reject-label {
  font-size: 24rpx;
  color: #f44336;
  font-weight: bold;
}

.reject-text {
  font-size: 24rpx;
  color: #666;
}
